@inproceedings{pei2025perplexmath,
  bibtex_show = {true},
  title       = {{PerplexMATH}: Steering {LLMs} Towards Mathematical Reasoning},
  author      = {Pei, Serena and others},
  booktitle   = {ICML 2025 NewInML Workshop},
  year        = {2025},
  html        = {https://github.com/jerryfrancis-97/llmination-reasoning},
  code        = {https://github.com/jerryfrancis-97/llmination-reasoning},
  selected    = {true},
  abstract    = {Large language models have demonstrated unprecedented progress in reasoning abilities, yet performance degrades on hard problems and is brittle under structural perturbations. This study investigates whether LLMs balance memorization and reasoning when solving hard math problems. Through systematic evaluation we find a computation-reasoning trade-off: models solve computationally intensive problems faster but with 50% less engagement in some models, suggesting heuristic shortcuts under load. We introduce PerplexMATH, a hard math problem dataset with diverse perturbation types and a reasoning framework for evaluating LLMs with more robust, human-like reasoning capabilities.},
  abbr        = {ICML},
  award       = {Accepted poster and presentation at **ICML 2025 NewInML Workshop**},
  award_name  = {ICML 2025}
}

